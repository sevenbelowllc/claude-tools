# Captured config — local only, EXCEPT global/CLAUDE.md, which is intentionally
# published so a fresh setup restores it. Everything else under global/, and all
# of project/, stays local.
global/*
!global/CLAUDE.md
project/

# Machine/account-specific values.
local.env

# Restore-time backups of overwritten files.
.restore-backup/

.DS_Store
