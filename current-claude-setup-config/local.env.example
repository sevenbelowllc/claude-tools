# Copy this file to local.env (gitignored) and set your real values.
# This keeps machine/account-specific paths and ids out of the public repo;
# capture.sh / restore.sh source it automatically.

# Absolute path to the project whose .claude config you're snapshotting:
export CLAUDE_SNAPSHOT_PROJ="$HOME/path/to/your/project"

# Your GCP project id. Usually already exported in your shell; uncomment to pin:
# export GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
